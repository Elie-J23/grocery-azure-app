<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register Customer</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <div class="brand">Grocery Cloud Store</div>
      <div>
        <a href="/">Home</a>
        <a href="/customers/login">Customer Login</a>
        <a href="/products/new">Add Product</a>
        <a href="/orders/history">Order History</a>
        <a href="/admin/dashboard">Admin Dashboard</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <section class="hero">
      <h1>Customer Registration</h1>
      <p>Create a customer profile stored in Azure Table Storage.</p>
    </section>

    <section class="form-wrap">
      <form method="POST" action="/customers/register">
        <label>Full Name</label>
        <input name="fullName" required />

        <label>Email</label>
        <input type="email" name="email" required />

        <label>Phone</label>
        <input name="phone" required />

        <label>Delivery Address</label>
        <input name="address" required />

        <button type="submit">Register Customer</button>
      </form>
    </section>
  </main>

  <footer class="footer">
    <div class="container">Customer data is logged and stored securely in Azure.</div>
  </footer>
</body>
</html>

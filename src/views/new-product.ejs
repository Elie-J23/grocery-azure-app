<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Product</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <div class="brand">Grocery Cloud Store</div>
      <div>
        <a href="/">Home</a>
        <a href="/customers/register">Register Customer</a>
        <a href="/customers/login">Customer Login</a>
        <a href="/orders/history">Order History</a>
        <a href="/admin/dashboard">Admin Dashboard</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <section class="hero">
      <h1>Add Grocery Product</h1>
      <p>Product metadata is stored in Azure Table and image files in Azure Blob Storage.</p>
    </section>

    <section class="form-wrap">
      <form method="POST" action="/products" enctype="multipart/form-data">
        <label>Product Name</label>
        <input name="name" required />

        <label>Category</label>
        <input name="category" required />

        <label>Price (USD)</label>
        <input type="number" step="0.01" name="price" required />

        <label>Stock Quantity</label>
        <input type="number" name="stock" required />

        <label>Description</label>
        <textarea name="description"></textarea>

        <label>Product Image</label>
        <input type="file" name="image" accept="image/*" />

        <button type="submit">Create Product</button>
      </form>
    </section>
  </main>

  <footer class="footer">
    <div class="container">Uploaded files are saved in Azure Blob container.</div>
  </footer>
</body>
</html>

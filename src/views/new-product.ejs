<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add New Product - Admin</title>
  <link rel="stylesheet" href="/styles.css" />

</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <div class="brand">🍎 Grocery Admin Portal</div>
      <div>
        <a href="/">🏠 Home</a>
        <a href="/admin/dashboard">📊 Dashboard</a>
        <a href="/orders/history">📋 Orders</a>
        <a href="/logout">🚪 Logout</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <section class="hero">
      <h1>➕ Add New Product</h1>
      <p><strong>Azure Table Storage:</strong> Product data | <strong>Azure Blob Storage:</strong> Images</p>
    </section>

    <section class="form-wrap">
      <form method="POST" action="/products" enctype="multipart/form-data">
        <div class="two-col">
          <div>
            <label>Product Name *</label>
            <input name="name" placeholder="Fresh Organic Tomatoes" required />
          </div>
          <div>
            <label>Category *</label>
            <select name="category" required>
              <option value="">Select...</option>
              <option value="Produce">🥬 Produce</option>
              <option value="Dairy">🧀 Dairy</option>
              <option value="Meat">🥩 Meat</option>
              <option value="Bakery">🍞 Bakery</option>
              <option value="Pantry">🥫 Pantry</option>
            </select>
          </div>
          <div>
            <label>Price *</label>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
              <span>$</span>
              <input type="number" step="0.01" min="0.01" name="price" placeholder="4.99" required />
            </div>
          </div>
          <div>
            <label>Stock *</label>
            <input type="number" min="0" name="stock" placeholder="50" required />
          </div>
        </div>

        <label>Description</label>
        <textarea name="description" placeholder="Describe the product..."></textarea>

        <label>Product Image</label>
        <input type="file" name="image" accept="image/*" />

        <div class="text-center">
          <button type="submit" class="btn">🚀 Create Product</button>
        </div>
      </form>
    </section>

    <section class="form-wrap notice-success">
      <h4>📋 Storage Flow:</h4>
      <ul style="margin: 1rem 0; padding-left: 1.5rem;">
        <li>✅ Table Storage: Product record</li>
        <li>✅ Blob Storage: Image file</li>
        <li>✅ Files Storage: Activity log</li>
      </ul>
    </section>
  </main>

  <script>
    const imageInput = document.getElementById('image');
    const preview = document.getElementById('preview');
    const uploadZone = document.querySelector('.upload-zone');

    imageInput.addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          preview.src = e.target.result;
          preview.style.display = 'block';
        }
        reader.readAsDataURL(file);
        uploadZone.innerHTML = `
          <div class="upload-icon">✅</div>
          <p><strong>${file.name}</strong> selected</p>
          <p class="meta">${(file.size/1024/1024).toFixed(1)} MB • ${file.type}</p>
        `;
      }
    });

    // Drag & drop
    uploadZone.addEventListener('dragover', e => {
      e.preventDefault();
      uploadZone.classList.add('dragover');
    });
    uploadZone.addEventListener('dragleave', () => {
      uploadZone.classList.remove('dragover');
    });
    uploadZone.addEventListener('drop', e => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      imageInput.files = e.dataTransfer.files;
      imageInput.dispatchEvent(new Event('change'));
    });
  </script>

  <footer class="footer">
    <div class="container">Admin product management | Azure Storage Services Integration</div>
  </footer>
</body>
</html>

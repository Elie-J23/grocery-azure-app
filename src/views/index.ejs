<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grocery Cloud Store - Fresh Groceries Delivered</title>
  <link rel="stylesheet" href="/styles.css" />

</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <div class="brand">🍎 Grocery Cloud Store</div>
      <div>
        <a href="/">🏠 Home</a>
        <a href="/products/new">➕ Add Product</a>
        <a href="/customers/register">📝 Register</a>
        <a href="/customers/login">🔑 Login</a>
        <a href="/admin/dashboard">📊 Dashboard</a>
      </div>
    </div>
  </nav>

  <main class="container">
<h2>Featured Products</h2>

    <% if (error) { %>
      <section class="form-wrap notice-error">
        <p><strong>⚠️ <%= error %></strong></p>
      </section>
    <% } %>

    <section id="featured" class="grid">
      <% if (!products || products.length === 0) { %>
        <div class="card text-center">
          <div style="height: 170px; background: linear-gradient(45deg, #f3f4f6, #e5e7eb); display: flex; align-items: center; justify-content: center;">
            <span style="font-size: 2rem; color: var(--muted);">📦</span>
          </div>
          <h3>No products available</h3>
          <p class="meta">Be the first to add groceries!</p>
          <a class="btn" href="/products/new">⚙️ Add First Product</a>
        </div>
      <% } else { %>
        <% products.slice(0, 6).forEach(function(product){ %>
          <article class="card">
            <% if (product.imageUrl) { %>
              <img src="<%= product.imageUrl %>" alt="<%= product.name || 'Product image' %>" loading="lazy" />
            <% } else { %>
              <div style="height: 170px; background: linear-gradient(45deg, #f3f4f6, #e5e7eb); display: flex; align-items: center; justify-content: center;">
                <span style="font-size: 2.5rem; opacity: 0.5;">🛒</span>
              </div>
            <% } %>
            <h3><%= product.name || 'Product' %></h3>
            <p class="meta"><strong><%= product.category || 'Grocery' %></strong></p>
            <p class="price">$<%= product.price || '0.00' %></p>
            <p class="meta"><%= product.stock > 0 ? 'In Stock' : 'Out of Stock' %></p>
            <% if (product.stock > 0) { %>
              <a class="btn" href="/orders/new/<%= product.rowKey %>">🛒 Add to Order</a>
            <% } %>
          </article>
        <% }) %>
      <% } %>
    </section>

    <section class="form-wrap text-center">
      <h3>🍽️ Popular Categories</h3>
      <p class="meta">Fresh Produce • Dairy • Meat • Bakery • Pantry Essentials</p>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      ABC Retail Grocery Application | Powered by Azure Table/Blob/Queue/Files Storage ⚡
      <br><small>Admin: admin/admin123 | Optimized for fast cloud grocery shopping</small>
    </div>
  </footer>
</body>
</html>


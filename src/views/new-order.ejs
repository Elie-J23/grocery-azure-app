<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Place Order</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <nav class="nav">
    <div class="container nav-inner">
      <div class="brand">Grocery Cloud Store</div>
      <div>
        <a href="/">Home</a>
        <a href="/customers/register">Register Customer</a>
        <a href="/customers/login">Customer Login</a>
        <a href="/products/new">Add Product</a>
        <a href="/orders/history">Order History</a>
        <a href="/admin/dashboard">Admin Dashboard</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <section class="hero">
      <h1>Place Order</h1>
      <p>Order details are captured and processed with queue-based workflow.</p>
      <% if (error) { %>
        <p class="meta"><strong>Notice:</strong> <%= error %></p>
      <% } %>
    </section>

    <section class="form-wrap">
      <h3><%= product.name || "Selected Product" %></h3>
      <p class="meta"><strong>Price:</strong> $<%= product.price || "0.00" %></p>
      <p class="meta"><strong>Current Stock:</strong> <%= product.stock || "0" %></p>

      <form method="POST" action="/orders">
        <input type="hidden" name="productId" value="<%= product.rowKey %>" />

        <label>Customer ID</label>
        <input name="customerId" placeholder="Enter registered customer ID" required />

        <label>Quantity</label>
        <input type="number" min="1" name="quantity" required />

        <label>Payment Method</label>
        <select name="paymentMethod" required>
          <option value="Card">Card</option>
          <option value="Debit">Debit</option>
          <option value="Visa">Visa</option>
        </select>

        <button type="submit">Submit Order</button>
      </form>
    </section>

    <section class="form-wrap">
      <h3>Background Worker</h3>
      <p class="meta">Process one message from orders queue and update stock.</p>
      <form method="POST" action="/worker/process-order">
        <button type="submit">Run Order Processing Worker</button>
      </form>
    </section>
  </main>

  <footer class="footer">
    <div class="container">Queue-driven processing keeps the app responsive during peak demand.</div>
  </footer>
</body>
</html>
